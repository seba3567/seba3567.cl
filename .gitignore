# Vite
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# Original image sources (canonical copies live in static/, optimized
# variants generated by scripts/optimize-images.mjs on prebuild)
# IMPORTANT: only the ROOT /assets/ dir is ignored (Vite build output).
# /static/assets/ is the canonical source for our icons — keep tracked.
assets/
!static/assets/
!static/assets/**

# Generated optimized images (re-generated on every prebuild)
# NOTE: we keep the SOURCE (jpg/png/avif) in git but ignore the
# generated variants — they're rebuilt on every prebuild/predev.
static/**/*.avif
static/**/*.webp
static/**/*@2x.avif
static/**/*@2x.webp

